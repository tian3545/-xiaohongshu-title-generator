# 邮箱配置（使用免费邮箱，如QQ邮箱、163邮箱）
SMTP_SERVER=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_smtp_password

# JWT配置（修改为随机字符串）
SECRET_KEY=your-secret-key-change-this-in-production-please-use-random-string

# 微信支付配置（可选，用于正式支付）
WECHAT_APPID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_NOTIFY_URL=https://your-app.onrender.com/api/payment/notify

# 支付宝配置（可选）
ALIPAY_APPID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=https://your-app.onrender.com/api/payment/notify

# 数据库路径
DB_PATH=data/app.db

# 调试模式
DEBUG=false

# 服务器配置
HOST=0.0.0.0
PORT=8000
